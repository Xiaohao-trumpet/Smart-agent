# Model Configuration
MODEL_NAME=qwen-plus
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_KEY=your_api_key_here
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1024
SYSTEM_PROMPT_SCENE=default

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Session Configuration
SESSION_TTL_SECONDS=3600
SESSION_CLEANUP_INTERVAL=300

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# CORS Configuration
CORS_ORIGINS=*

# Memory System (Phase 2)
MEMORY_ENABLED=true
LONG_TERM_MEMORY_ENABLED=true
MEMORY_WRITE_ENABLED=true

# Short-term memory
SHORT_TERM_WINDOW_TURNS=6
SHORT_TERM_ENABLE_SUMMARY=true
SHORT_TERM_SUMMARY_TRIGGER_TURNS=10
SHORT_TERM_SUMMARY_MAX_CHARS=800

# Long-term memory
MEMORY_PERSIST_DIR=./data/memory
MEMORY_VECTOR_BACKEND=chroma
MEMORY_COLLECTION_NAME=user_memories
MEMORY_SEARCH_TOP_K=3

# Embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=256
EMBEDDING_USE_REMOTE=true
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your_api_key_here
